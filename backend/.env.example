# Server Port Configuration
PORT=5000

# CORS Allowed Origins
FRONTEND_URL=http://localhost:5173

# GoDaddy / Custom Domain SMTP Settings
# For GoDaddy Office 365, use: smtp.office365.com (port 587)
# For GoDaddy Workspace Email, use: smtpout.secureserver.net (port 465 or 80 or 3535)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=connect@pikuboo.com
SMTP_PASS=your_email_password_or_app_password

# Email Recipient Settings
RECIPIENT_EMAIL=connect@pikuboo.com
